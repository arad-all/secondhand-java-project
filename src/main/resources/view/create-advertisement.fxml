<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="10" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="frontend.controller.CreateAdvertisementController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <Label style="-fx-font-size: 22px; -fx-font-weight: bold;" text="New Advertisement"/>

    <TextField fx:id="titleField" promptText="Title"/>
    <TextArea fx:id="descriptionField" prefRowCount="4" promptText="Description"/>
    <TextField fx:id="priceField" promptText="Price"/>
    <ComboBox fx:id="categoryComboBox" prefWidth="260" promptText="Category"/>
    <ComboBox fx:id="cityComboBox" prefWidth="260" promptText="City"/>

    <Button onAction="#handleSubmit" text="Submit"/>
    <Button onAction="#handleCancel" text="Back to Browse"/>

    <Label fx:id="errorLabel" wrapText="true"/>
</VBox>
